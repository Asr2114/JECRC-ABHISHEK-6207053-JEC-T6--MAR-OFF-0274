          "name": "Add Shopper",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "let res = pm.response.json();",
                  "",
                  "let shopperId = res.data.userId;",
                  "",
                  "pm.environment.set(\"shopperId\", shopperId);",
                  "",
                  "let email = res.data.email;",
                  "",
                  "pm.environment.set(\"shopperEmail\", email);",
                  "",
